# ============================================================
# BACKEND — Go server (Google Cloud Run)
# Store these in GCP Secret Manager and reference via cloudbuild.yaml
# ============================================================

# Required
GEMINI_API_KEY=AIza...
CONTROL_PLANE_DATABASE_URL=postgres://user:pass@host/db?sslmode=require
POSTGRES_BASE_DSN=postgres://user:pass@host/

# Optional
# GEMINI_MODEL=models/gemini-2.5-flash-native-audio-latest
# HTTP_ADDR=:8080               # Cloud Run overrides this via PORT automatically
CORS_ORIGIN=https://your-app.vercel.app

# Cloudflare R2 audio storage
R2_ENDPOINT=https://accountid.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=your-bucket
R2_REGION=auto

# Meta / WhatsApp Business API
META_APP_ID=...
META_APP_SECRET=...

# ============================================================
# FRONTEND — Next.js (Vercel)
# Set these in the Vercel project dashboard under Settings > Environment Variables
# ============================================================

# JWT session secret — generate with: openssl rand -base64 32
SESSION_SECRET=at-least-32-chars-random-string

# Server-side Go backend URL (used by Next.js API routes — not exposed to browser)
API_URL=https://your-backend.run.app

# Client-side URLs (exposed to browser)
NEXT_PUBLIC_API_URL=https://your-backend.run.app
NEXT_PUBLIC_WS_URL=wss://your-backend.run.app
